# -----------------------------------------------------
#  APP CONFIG
# -----------------------------------------------------
APP_NAME="ChooseATaxi"
APP_ENV=production
APP_DEBUG=false
APP_URL="https://chooseataxi.com"

# -----------------------------------------------------
#  DATABASE CONFIG
# -----------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chooseataxi
DB_USER=root
DB_PASS=yourpassword

# -----------------------------------------------------
#  JWT AUTHENTICATION
# -----------------------------------------------------
JWT_SECRET=your_jwt_secret_key_32_characters_minimum
JWT_EXPIRE_MIN=43200   # 30 days

# -----------------------------------------------------
#  GOOGLE MAPS / PLACES APIs
# -----------------------------------------------------
GOOGLE_MAPS_KEY=your_google_maps_key
GOOGLE_PLACES_KEY=your_google_places_key
GOOGLE_GEO_API_KEY=your_google_geocode_key

# -----------------------------------------------------
#  FIREBASE CLOUD MESSAGING (NOTIFICATIONS)
# -----------------------------------------------------
FIREBASE_SERVER_KEY=your_firebase_fcm_key
FIREBASE_SENDER_ID=your_sender_id

# -----------------------------------------------------
#  SMS / OTP PROVIDER CONFIG
# -----------------------------------------------------
SMS_PROVIDER=fast2sms
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=CHOOSE
OTP_EXPIRY_MIN=5

# -----------------------------------------------------
#  EMAIL / SMTP CONFIG
# -----------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@chooseataxi.com
MAIL_FROM_NAME="Choose A Taxi"

# -----------------------------------------------------
#  STORAGE PATHS
# -----------------------------------------------------
UPLOAD_PATH_DRIVER=uploads/drivers/
UPLOAD_PATH_CUSTOMER=uploads/customers/
UPLOAD_PATH_RIDES=uploads/rides/

# -----------------------------------------------------
#  APP SETTINGS
# -----------------------------------------------------
LOCATION_UPDATE_INTERVAL=5   # driver location update every 5s
MAX_LOGIN_ATTEMPTS=5
LOG_CHANNEL=single   # daily / single